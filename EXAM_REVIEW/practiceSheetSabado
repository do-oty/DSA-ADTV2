#include &lt;string.h&gt;

// Enum for status
typedef enum {
STATUS_ACTIVE,
STATUS_INACTIVE,
STATUS_SUSPENDED
} Status;

// Nested struct for date
typedef struct {
int day;
int month;
int year;
} Date;

// Struct for address
typedef struct {
char street[100];
char city[50];
char zip[10];
} Address;

// Union for different ID types
typedef union {
int national_id;
char passport[20];
} ID;

// Project node (linked list)
typedef struct Project {
int project_id;
char project_name[100];
struct Project *next;
} Project;

// Main Employee struct
typedef struct Employee {
int id;
char name[100];
Status status;

Date hire_date;
Address address;
ID id_info;

Project *projects; // head of linked list

} Employee;

